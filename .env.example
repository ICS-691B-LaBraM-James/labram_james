# Ollama server URL (default assumes Ollama running on host machine)
# When running backend in Docker, host.docker.internal resolves to the host.
# When running backend directly, use http://localhost:11434.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Orchestrator model (conversational LLM)
ORCHESTRATOR_MODEL=llama3.1

# Report generator model (use the same vetted model as the orchestrator; meditron omitted—hallucinations)
REPORT_MODEL=llama3.1

# Docker image runs uvicorn with --ws-max-size 512MiB (see backend/Dockerfile). For local uvicorn without Docker, add the same flag if uploads fail or close with WebSocket 1009.
# Example: uvicorn main:app --host 0.0.0.0 --port 8000 --ws-max-size 536870912

# HuggingFace token for loading LaBraM weights (future)
HUGGINGFACE_TOKEN=
